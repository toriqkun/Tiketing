generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username             String   @unique @db.VarChar(100)
  email                String   @unique @db.VarChar(255)
  phone                String   @db.VarChar(30)
  password_hash        String
  must_change_password Boolean  @default(false)
  is_admin             Boolean  @default(false)
  status               String   @default("activated") @db.VarChar(20)
  effective_time       DateTime @db.Timestamptz
  expired_time         DateTime @db.Timestamptz
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz

  tickets_targeted  Ticket[]          @relation("TargetAccount")
  tickets_requested Ticket[]          @relation("RequesterAccount")
  audit_logs        AccountAuditLog[] @relation("TargetAuditAccount")
  audit_logs_actor  AccountAuditLog[] @relation("ActorAuditAccount")
  ticket_histories  TicketHistory[]

  @@map("accounts")
}

model Ticket {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_number   String @unique @db.VarChar(30)
  ticket_type     String @db.VarChar(20)
  status          String @default("running") @db.VarChar(20)
  current_phase   String @default("approval") @db.VarChar(20)
  description     String
  target_username String @db.VarChar(100)
  target_email    String @db.VarChar(255)
  target_phone    String @db.VarChar(30)

  target_account_id String?  @db.Uuid
  target_account    Account? @relation("TargetAccount", fields: [target_account_id], references: [id], onDelete: SetNull)

  requester_id String?  @db.Uuid
  requester    Account? @relation("RequesterAccount", fields: [requester_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  histories TicketHistory[]

  @@index([status])
  @@index([current_phase])
  @@index([requester_id])
  @@index([target_account_id])
  @@map("tickets")
}

model TicketHistory {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id String @db.Uuid
  ticket    Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  phase  String @db.VarChar(20)
  action String @db.VarChar(30)

  actor_id String?  @db.Uuid
  actor    Account? @relation(fields: [actor_id], references: [id], onDelete: SetNull)

  description String?
  proof_image String?

  created_at DateTime @default(now()) @db.Timestamptz

  @@map("ticket_history")
}

model AccountAuditLog {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String  @db.Uuid
  account    Account @relation("TargetAuditAccount", fields: [account_id], references: [id], onDelete: Cascade)

  action String @db.VarChar(30)

  actor_id String?  @db.Uuid
  actor    Account? @relation("ActorAuditAccount", fields: [actor_id], references: [id], onDelete: SetNull)

  changes Json?

  created_at DateTime @default(now()) @db.Timestamptz

  @@map("account_audit_log")
}
